fun Add(const v1: f32, const v2: f32) -> f32:
    return v1 + v2;
end

fun Div(const v1: f32, const v2: f32) -> f32:
    if(v2 == 0):
        Panic("Division by zero");
    end

    return v1 / v2;
end

fun Mul(const v1: f32, const v2: f32) -> f32:
    return v1 * v2;
end

fun Sub(const v1: f32, const v2: f32) -> f32:
    return v1 - v2;
end

Add(10, 20);
Div(10, 20);
Mul(10, 20);
Sub(10, 20);
