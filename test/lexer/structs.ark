module Person;
import System::Data;

enum EmployeePosition:
    DEVELOPER,
    HR,
    SUPPLY_CHAIN,
    CTO,
    CFO,
    CEO
end

internal struct Person:
    var name: string;
    var age: i8;
end

struct Employee extends !Person:
    var position: EmployeePosition = EmployeePosition::DEVELOPER;
    var salary: f64 = 0;
    var active: bool = true;
    var create_at: Date;
    var modified_at: Date;
end

fun Employee::New() -> Employee:
    var obj = Employee 
    { 
        name: "Jhon Due",
        age: 32,
        salary: 5000.0,
        create_at: Date::New(),
        modified_at: Date::New(),
    };

    return obj;
end

fun Employee::Copy(target: Employee) -> Employee:
    var obj: Employee = Employee
    { 
        name: target::name,
        age: target::age,
        salary: target::salary,
        create_at: target::create_at,
        modified_at: target::modified_at,
    };

    return obj;
end

